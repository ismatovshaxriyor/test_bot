# Telegram Bot Token (BotFather dan oling)
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID (o'zingizning telegram ID ingiz)
ADMIN_ID=your_telegram_id_here

# Bot username (@siz yozsangiz ham bo'ladi)
BOT_USERNAME=your_bot_username_here

# Avtomatik DB zaxirasi: necha soatda bir marta adminga yuborilsin (0 = o'chirilgan)
BACKUP_INTERVAL_HOURS=12
